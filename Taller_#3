# ============================================
#   PROPIEDAD 6
# ============================================

print("\nPropiedad 6: Dependencia lineal")

A = np.array([[1,2,3],[2,4,6],[3,1,0]])
mostrar("Matriz A", A)
print("det(A):", np.linalg.det(A))


B = np.array([[2,1,3],[4,2,6],[1,0,1]])
mostrar("Matriz B", B)
