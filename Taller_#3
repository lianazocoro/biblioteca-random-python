# ============================================
#   PROPIEDAD 7
# ============================================

print("\nPropiedad 7: Matriz identidad")

I = np.identity(3)
mostrar("Matriz identidad", I)
print("det(I):", np.linalg.det(I))


I2 = np.identity(3)
mostrar("Matriz identidad (otra vez)", I2)
print("det(I):", np.linalg.det(I2))


# ============================================
#   PROPIEDAD 8
# ============================================

print("\nPropiedad 8: Determinante del producto")

A = np.array([[1,2,0],[0,1,3],[2,1,1]])
B = np.array([[2,0,1],[1,3,2],[0,1,1]])

mostrar("Matriz A", A)
mostrar("Matriz B", B)

detA = np.linalg.det(A)
detB = np.linalg.det(B)
detAB = np.linalg.det(np.dot(A, B))

print("det(A):", detA)
print("det(B):", detB)
print("det(A)*det(B):", detA * detB)
print("det(AB):", detAB)


A = np.array([[2,1,0],[1,0,3],[4,2,1]])
B = np.array([[1,2,1],[0,1,0],[2,3,4]])

mostrar("Matriz A (caso 2)", A)
mostrar("Matriz B (caso 2)", B)

detA = np.linalg.det(A)
detB = np.linalg.det(B)
detAB = np.linalg.det(np.dot(A, B))

print("det(A):", detA)
print("det(B):", detB)
print("det(A)*det(B):", detA * detB)
print("det(AB):", detAB)


# ============================================
#   PROPIEDAD 9
# ============================================

print("\nPropiedad 9: Determinante de la traspuesta")

A = np.array([[1,2,3],[0,1,4],[2,0,1]])

mostrar("Matriz A", A)
mostrar("Matriz A^T", A.T)

print("det(A):", np.linalg.det(A))
print("det(A^T):", np.linalg.det(A.T))


B = np.array([[3,1,2],[2,0,1],[1,4,3]])

mostrar("Matriz B", B)
mostrar("Matriz B^T", B.T)

print("det(B):", np.linalg.det(B))
print("det(B^T):", np.linalg.det(B.T))


